# Variáveis de Configuração

# Diretório de entrada PBIX
PBIX_INPUT_DIR=./pbix/

# Diretório de extração
PBIX_EXTRACT_DIR=./extracted/

# Diretório de saída PBIX
PBIX_OUTPUT_DIR=./pbix/

# Python
PYTHON_VERSION=3.8+

# Node.js
NODE_VERSION=16+

# MCP Server
MCP_SERVER_PORT=3000

# Desenvolvimento (false para produção)
DEBUG=false
